generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("analyst")
  accounts      Account[]
  sessions      Session[]
  models        DCFModel[]
  createdAt     DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model DCFModel {
  id                String          @id @default(cuid())
  userId            String
  ticker            String
  companyName       String
  currency          String          @default("USD")
  modelData         String          // JSON blob
  activeScenario    String          @default("base")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions          ModelVersion[]
  assumptionChanges AssumptionChange[]
  @@index([userId])
  @@index([ticker])
}

model ModelVersion {
  id          String   @id @default(cuid())
  modelId     String
  versionNum  Int
  label       String?  // e.g. "Post-earnings update", "Q3 guidance"
  modelData   String   // full JSON snapshot
  baseIVPS    Float?
  bearIVPS    Float?
  bullIVPS    Float?
  createdAt   DateTime @default(now())
  createdBy   String   // userId
  model       DCFModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  @@index([modelId])
}

model AssumptionChange {
  id         String   @id @default(cuid())
  modelId    String
  field      String   // e.g. "waccBase"
  oldValue   String   // stored as string for flexibility
  newValue   String
  changedAt  DateTime @default(now())
  changedBy  String   // userId
  model      DCFModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  @@index([modelId])
  @@index([changedAt])
}
